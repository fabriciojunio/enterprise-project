# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_NAME=EnterpriseApp
APP_VERSION=1.0.0
PORT=3001
API_PREFIX=/api/v1

# ============================================
# SECURITY
# ============================================
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production-min-64chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-64chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12
ENCRYPTION_KEY=your-32-char-encryption-key-here

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=enterprise_db
DB_USER=enterprise_user
DB_PASSWORD=your-strong-db-password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TTL=3600

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# STORAGE
# ============================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_DIR=./logs
